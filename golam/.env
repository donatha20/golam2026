# Django Settings
SECRET_KEY=django-insecure-development-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (SQLite for development)
DATABASE_URL=sqlite:///db.sqlite3
DB_NAME=microfinance_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# SMS Configuration (Development - will log to console)
SMS_API_KEY=development-key
SMS_API_URL=https://api.example.com/send
SMS_SENDER_ID=MicroFinance

# Email Configuration (Development - will log to console)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False

# Admin Email for Testing
ADMIN_EMAIL=golamfinancialservices@gmail.com
DEFAULT_FROM_EMAIL=noreply@golamfinancial.co.tz

# File Upload Settings
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# System Settings
DEFAULT_CURRENCY=TSH
DEFAULT_INTEREST_RATE=15.0
DEFAULT_LOAN_DURATION=12
BACKUP_RETENTION_DAYS=30

# Security Settings
SESSION_COOKIE_AGE=3600
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False

# Testing Settings
AUTO_APPROVE_USERS=True
